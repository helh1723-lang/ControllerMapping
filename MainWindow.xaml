<Window x:Class="GameControllerMapper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="手柄键鼠映射" Width="1120" Height="760" MinWidth="920" MinHeight="620"
        WindowStartupLocation="CenterScreen" Background="#F5F7FB">
  <Window.Resources>
    <Style TargetType="Button">
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="Margin" Value="3" />
    </Style>
    <Style TargetType="ComboBox">
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Margin" Value="3" />
    </Style>
    <Style TargetType="GroupBox">
      <Setter Property="Margin" Value="8" />
      <Setter Property="Padding" Value="8" />
    </Style>
  </Window.Resources>

  <DockPanel>
    <Border DockPanel.Dock="Top" Background="#17233C" Padding="18,14">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="260" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="220" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock Text="设备" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0" />
        <ComboBox x:Name="DeviceCombo" Grid.Column="1" SelectionChanged="DeviceCombo_SelectionChanged" />
        <TextBlock Grid.Column="2" Text="配置" Foreground="White" VerticalAlignment="Center" Margin="16,0,8,0" />
        <ComboBox x:Name="ProfileCombo" Grid.Column="3" DisplayMemberPath="Name" SelectionChanged="ProfileCombo_SelectionChanged" />
        <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="8,0">
          <Button Content="新建" Click="NewProfile_Click" />
          <Button Content="复制" Click="CopyProfile_Click" />
          <Button Content="重命名" Click="RenameProfile_Click" />
          <Button Content="删除" Click="DeleteProfile_Click" />
        </StackPanel>
        <ToggleButton x:Name="MappingToggle" Grid.Column="5" Width="122" Height="38"
                      Content="映射已关闭" FontWeight="SemiBold" Click="MappingToggle_Click" />
      </Grid>
    </Border>

    <Border DockPanel.Dock="Bottom" Background="White" BorderBrush="#DCE2EE" BorderThickness="0,1,0,0" Padding="12,8">
      <DockPanel>
        <TextBlock x:Name="StatusText" Text="正在查找手柄…" Foreground="#46536B" />
        <TextBlock DockPanel.Dock="Right" Text="紧急关闭：Ctrl + Alt + F12" Foreground="#6C7890" />
      </DockPanel>
    </Border>

    <TabControl Margin="12">
      <TabItem Header="键位映射">
        <Grid Margin="4">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
          </Grid.ColumnDefinitions>

          <DataGrid x:Name="MappingGrid" AutoGenerateColumns="False" IsReadOnly="True"
                    HeadersVisibility="Column" GridLinesVisibility="Horizontal" CanUserAddRows="False"
                    Background="White" BorderBrush="#DCE2EE" RowHeight="40">
            <DataGrid.RowStyle>
              <Style TargetType="DataGridRow">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="Background" Value="#DFF7E8" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
              <DataGridTextColumn Header="手柄输入" Binding="{Binding DisplayName}" Width="2*" />
              <DataGridTextColumn Header="映射输出" Binding="{Binding BindingText}" Width="3*" />
              <DataGridTemplateColumn Header="操作" Width="150">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                      <Button Content="设置" Click="EditBinding_Click" />
                      <Button Content="清除" Click="ClearBinding_Click" />
                    </StackPanel>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
            </DataGrid.Columns>
          </DataGrid>

          <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
              <GroupBox Header="摇杆模式">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>
                  <Grid.ColumnDefinitions><ColumnDefinition /><ColumnDefinition Width="150" /></Grid.ColumnDefinitions>
                  <TextBlock Text="左摇杆" VerticalAlignment="Center" />
                  <ComboBox x:Name="LeftStickModeCombo" Grid.Column="1" DisplayMemberPath="Label" SelectionChanged="SettingsChanged" />
                  <TextBlock Grid.Row="1" Text="右摇杆" VerticalAlignment="Center" />
                  <ComboBox x:Name="RightStickModeCombo" Grid.Row="1" Grid.Column="1" DisplayMemberPath="Label" SelectionChanged="SettingsChanged" />
                </Grid>
              </GroupBox>

              <GroupBox Header="灵敏度与校准">
                <StackPanel>
                  <TextBlock x:Name="DeadzoneLabel" />
                  <Slider x:Name="DeadzoneSlider" Minimum="0" Maximum="0.9" TickFrequency="0.01" ValueChanged="SettingsChanged" />
                  <TextBlock x:Name="DirectionLabel" Margin="0,10,0,0" />
                  <Slider x:Name="DirectionSlider" Minimum="0.1" Maximum="1" TickFrequency="0.01" ValueChanged="SettingsChanged" />
                  <TextBlock x:Name="TriggerLabel" Margin="0,10,0,0" />
                  <Slider x:Name="TriggerSlider" Minimum="0.05" Maximum="1" TickFrequency="0.01" ValueChanged="SettingsChanged" />
                  <TextBlock x:Name="MouseSpeedLabel" Margin="0,10,0,0" />
                  <Slider x:Name="MouseSpeedSlider" Minimum="50" Maximum="5000" TickFrequency="50" ValueChanged="SettingsChanged" />
                </StackPanel>
              </GroupBox>

              <GroupBox Header="说明">
                <TextBlock TextWrapping="Wrap" Foreground="#566178"
                           Text="四方向模式会使用表格中的摇杆方向映射；鼠标模式会按摇杆力度连续移动鼠标。扳机按设定阈值作为按钮使用。" />
              </GroupBox>
            </StackPanel>
          </ScrollViewer>
        </Grid>
      </TabItem>

      <TabItem Header="设备检测">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="18">
            <TextBlock Text="实时输入检测" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Margin="0,6,0,18" Foreground="#5C6880" TextWrapping="Wrap"
                       Text="按下手柄按键查看 Windows 实际上报的输入。特殊键若始终没有出现，说明它被手柄固件保留，程序无法单独映射。" />
            <GroupBox Header="标准输入">
              <TextBlock x:Name="LiveButtonsText" Text="无" TextWrapping="Wrap" FontSize="16" />
            </GroupBox>
            <GroupBox Header="摇杆与扳机">
              <TextBlock x:Name="LiveAxesText" Text="等待输入…" FontFamily="Consolas" FontSize="16" />
            </GroupBox>
            <GroupBox Header="原始 HID 按钮">
              <TextBlock x:Name="LiveRawText" Text="无" TextWrapping="Wrap" FontSize="16" />
            </GroupBox>
            <Button Content="刷新设备列表" HorizontalAlignment="Left" Click="RefreshDevices_Click" />
          </StackPanel>
        </ScrollViewer>
      </TabItem>
    </TabControl>
  </DockPanel>
</Window>
